# ============================================================================
# Infisical secrets backend — bootstrap env (Kanban #2488, Phase 1, DRAFT)
# Append these to your .env when using `--profile secrets`. Decisions: plan.md §0.
# ============================================================================

# --- Infisical infrastructure (its OWN keys — NEVER store these inside Infisical) ---
# !!! BACK UP ENCRYPTION_KEY + AUTH_SECRET AS 2 ENCRYPTED EXPORTED COPIES (decision §0.3) !!!
# !!! Losing ENCRYPTION_KEY makes ALL stored secrets PERMANENTLY unrecoverable, even with !!!
# !!! an infisical-pgdata backup. Back up the keys AS A PAIR with that volume.            !!!
INFISICAL_ENCRYPTION_KEY=        # openssl rand -hex 16
INFISICAL_AUTH_SECRET=           # openssl rand -base64 32
INFISICAL_POSTGRES_USER=infisical
INFISICAL_POSTGRES_PASSWORD=     # set a strong password
INFISICAL_POSTGRES_DB=infisical
INFISICAL_SITE_URL=http://localhost:6080
INFISICAL_PORT=6080              # host port -> container 8080 (6xxx; avoids our 5432/8456/5431/8465)

# --- agent-teams api -> Infisical (these 3 stay in .env; they are NOT secrets) ---
# Empty INFISICAL_TOKEN = .env-only mode (DEFAULT, unchanged behavior). Set all three to enable.
INFISICAL_TOKEN=                 # machine-identity access token — read-only, scoped to the project
INFISICAL_PROJECT_ID=            # the Infisical project holding agent-teams secrets
INFISICAL_ENV=dev                # environment slug (dev / prod)
INFISICAL_DOMAIN=http://infisical-backend:8080    # SELF-HOST: api CLI targets OUR backend (verified current var name; legacy INFISICAL_API_URL also honored); compose-internal hostname
INFISICAL_DISABLE_UPDATE_CHECK=true               # skip the CLI's per-run outbound update check

# ----------------------------------------------------------------------------
# Migration is PHASED (decision §0.2). Step 1 migrates NOTHING — keep ALL existing
# secrets in .env and just prove Infisical infra + the .env path both work. Then
# step 2 (app DB creds + CREDENTIALS_MASTER_KEY) -> step 3 (active) -> step 4 (API keys).
# KEEP each secret in .env even after adding it to Infisical (decision §0.4): `infisical
# run` OVERRIDES at runtime, the .env copy is the fallback. The .env-only path stays
# first-class for non-Infisical installs.
# WARNING: if the app DB password later moves into Infisical, the Alembic migration
# command must ALSO run under `infisical run`, or migrations cannot reach the DB.
# ----------------------------------------------------------------------------
