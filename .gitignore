.superpowers/
.claude/projects/
.claude/settings.local.json
# git worktrees (transparent to git via gitfile; ignored here to keep `git status` clean)
.claude/worktrees/
/docs/

# Env / secrets
.env
.env.local
*.env

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Node
node_modules/
.next/
dist/
build/

# DB
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# Per-project per-role state — private per machine, not committed.
# context/projects/<project>/shared/ is committed (team-shared contract).
# context/projects/<project>/<role>/ is ignored except for .gitkeep.
# Pattern: any subfolder of a project except `shared/` is treated as role-private.
context/projects/*/*/
!context/projects/*/shared/
!context/projects/*/shared/**
!context/projects/*/*/.gitkeep

# Migrated out of repo (Kanban #1185, 2026-05-18) — secretary project lives at
# C:/Users/banku/Documents/Personal/Projects/WebApp/secretary as plain working folder.
# Guard against future auto-scaffold accidentally re-creating the dir here.
context/projects/secretary/

# Test fixtures from api/tests/test_routes_smoke.py — POST /api/projects auto-scaffolds
# folders, the tests soft-delete the DB row but leave the on-disk dir behind.
# rmtree-on-teardown is a follow-up (Kanban #17 M8); ignore the prefix-pattern for now.
context/projects/proj-*/

# Probe / smoke / backfill scaffold projects — convention: name MUST start with `_`
# so smoke-checklist.md / release-checklist.md probes don't pollute the working tree.
# Real projects use bare names (e.g., `agent-teams`, `myapp`).
context/projects/_*/

# Scratch dir for assistant-side tempfiles (POST payloads, JSON drafts, ad-hoc
# probe scripts). Keep the dir tracked via .gitkeep but ignore its contents.
_scratch/*
!_scratch/.gitkeep

# CTX-1 (Kanban #716): per-Claude-Code-instance session markdown store.
# DB rows live in `sessions` / `session_runs` / `session_compacts`; markdown
# content (session.md + archive/ + cards/) lives here. Never commit content.
/_sessions/

# Firecrawl research cache — local-only, ephemeral (#849 research notes live in _scratch/)
.firecrawl/

# Sandbox test projects — created via POST /api/projects for LangGraph smoke
context/projects/test-*/

# HITL push trigger smoke artifacts (#1450) — POST /api/projects auto-scaffolds
# folders for tests of the push-on-HITL-transition feature. Test projects use
# distinctive prefixes; ignore both patterns so `git status` stays clean.
context/projects/hitl-push-proj-*/
context/projects/smoke-push-*/

# Private / confidential strategic docs — per-machine, NEVER committed.
_private/

# Per-machine runtime state — Lead writes the session-bound project_id here at
# bootstrap (Kanban #1209 AC#2(d) — kill-switch hook contract). Keep the dir
# tracked via .gitkeep but ignore its contents (project_id is per-terminal).
_runtime/*
!_runtime/.gitkeep
