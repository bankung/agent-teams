# web/Dockerfile.prod — Multi-stage production image for the agent-teams Next.js UI.
#
# Produces a minimal standalone server (next.config.js: output: 'standalone').
# No source bind-mounts needed at runtime — the full app is baked in.
#
# Port: 5431 (matches docker-compose.yml WEB_PORT default).
#
# NEXT_PUBLIC_* build-time defaults (overridable via --build-arg):
#   NEXT_PUBLIC_API_URL              http://localhost:8456
#   NEXT_PUBLIC_FINANCE_PANELS_ENABLED false
#   NEXT_PUBLIC_VAPID_PUBLIC_KEY     (empty)
#
# These are inlined into the client bundle by Next.js at `next build` time.
# To change them you must rebuild the image with different ARG values.

# ── Stage 1: deps ─────────────────────────────────────────────────────────────
FROM node:20-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --prefer-offline

# ── Stage 2: builder ──────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Build-time ARGs for NEXT_PUBLIC_* vars.
# Next.js inlines these into the client bundle during `next build`.
ARG NEXT_PUBLIC_API_URL=http://localhost:8456
ARG NEXT_PUBLIC_FINANCE_PANELS_ENABLED=false
ARG NEXT_PUBLIC_VAPID_PUBLIC_KEY=

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_FINANCE_PANELS_ENABLED=$NEXT_PUBLIC_FINANCE_PANELS_ENABLED \
    NEXT_PUBLIC_VAPID_PUBLIC_KEY=$NEXT_PUBLIC_VAPID_PUBLIC_KEY \
    # Disable Next.js telemetry in CI / image builds.
    NEXT_TELEMETRY_DISABLED=1

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

# ── Stage 3: runner ───────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=5431 \
    HOSTNAME=0.0.0.0

# Non-root user for runtime security.
RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

# The standalone output includes a minimal node_modules tree.
# public/ and .next/static/ must be copied alongside it.
COPY --from=builder --chown=nextjs:nodejs /app/public                    ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone          ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static              ./.next/static

USER nextjs

EXPOSE 5431

# server.js is generated by Next.js standalone output.
# It reads PORT (set above) to decide which port to bind.
CMD ["node", "server.js"]
