{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",

      "Write(api/**)",
      "Write(web/**)",
      "Write(context/projects/**)",
      "Write(context/leads/**)",
      "Write(context/teams/**)",
      "Write(.claude/**)",
      "Edit(api/**)",
      "Edit(web/**)",
      "Edit(context/projects/**)",
      "Edit(context/leads/**)",
      "Edit(context/teams/**)",
      "Edit(.claude/**)",
      "Edit(CLAUDE.md)",
      "Edit(README.md)",
      "Edit(.gitignore)",
      "Edit(docker-compose.yml)",

      "Write(~/.claude/projects/**/memory/**)",
      "Edit(~/.claude/projects/**/memory/**)",

      "Write(_scratch/**)",
      "Edit(_scratch/**)",

      "Agent(*)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(git check-ignore:*)",
      "Bash(git stash list:*)",
      "Bash(git stash show:*)",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(cd:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",

      "Bash(curl --silent http://localhost:8456/api/:*)",
      "Bash(curl -s http://localhost:8456:*)",
      "Bash(curl -s http://localhost:8456/api/:*)",
      "Bash(curl --silent -X PATCH http://localhost:8456/api/:*)",
      "Bash(curl --silent -X POST http://localhost:8456/api/:*)",
      "Bash(curl --silent -X DELETE http://localhost:8456/api/:*)",
      "Bash(curl --silent http://localhost:8456:*)",
      "Bash(curl --silent -X POST http://localhost:8456:*)",
      "Bash(curl --silent -X PATCH http://localhost:8456:*)",
      "Bash(curl --silent -X DELETE http://localhost:8456:*)",
      "Bash(curl --silent \"http://localhost:8456:*)",
      "Bash(curl --silent -X POST \"http://localhost:8456:*)",
      "Bash(curl --silent -X PATCH \"http://localhost:8456:*)",
      "Bash(curl --silent -X DELETE \"http://localhost:8456:*)",

      "Bash(rm _scratch/:*)",
      "Bash(rm -r _scratch/:*)",
      "Bash(where:*)",

      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker inspect:*)",

      "Bash(docker compose exec api alembic current)",
      "Bash(docker compose exec api alembic heads)",
      "Bash(docker compose exec api alembic check)",
      "Bash(docker compose exec api alembic history:*)",
      "Bash(docker compose exec -T api alembic current)",
      "Bash(docker compose exec -T api alembic heads)",
      "Bash(docker compose exec -T api alembic check)",
      "Bash(docker compose exec -T api alembic history:*)",

      "Bash(docker compose exec api pytest:*)",
      "Bash(docker compose exec -T api pytest:*)",

      "Bash(docker compose exec -T api which:*)",
      "Bash(docker compose exec -T api pip-audit:*)",

      "Bash(docker compose exec db psql -U postgres -d agent_teams -c SELECT:*)",
      "Bash(docker compose exec -T db psql -U postgres -d agent_teams -c SELECT:*)",
      "Bash(docker compose exec db psql -U postgres -d agent_teams -c \\d:*)",
      "Bash(docker compose exec -T db psql -U postgres -d agent_teams -c \\d:*)"
    ],
    "ask": [
      "Write(*)",
      "Edit(*)",
      "Bash(*)"
    ]
  }
}
