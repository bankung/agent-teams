# Async DSN used by SQLAlchemy + asyncpg (FastAPI runtime)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_teams

# Sync DSN used by Alembic offline mode / tooling that doesn't speak asyncpg
# (Alembic env.py uses async_engine_from_config — this is here for ad-hoc use)
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/agent_teams

# App
APP_ENV=development
APP_DEBUG=true

# Kanban #1217 — Gmail SMTP relay for daily-digest email channel.
# 1. Enable 2FA on your Google Account.
# 2. Go to Google Account → Security → App Passwords.
# 3. Generate a 16-char app password for "Mail / Other (agent-teams)".
# 4. Paste the value (no spaces) into GMAIL_SMTP_APP_PASSWORD below.
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587
# GMAIL_SMTP_USER=your.address@gmail.com
# GMAIL_SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_SMTP_FROM=your.address@gmail.com
# DIGEST_EMAIL_RECIPIENT=your.address@gmail.com
# DIGEST_EMAIL_ENABLED=true
# WEB_BASE_URL=https://your.agent-teams.domain

# Kanban #1192 — ntfy push-notification channel.
# 1. Subscribe to a topic at ntfy.sh (or self-hosted ntfy).
# 2. Set NTFY_TOPIC to the topic name (e.g. bankung-agt-7x4q2k9w).
# 3. Set PUSH_ENABLED=true to enable.
# 4. NTFY_ACCESS_TOKEN is optional — only needed if the topic is auth-protected.
#    Strip any trailing comments from the value (e.g. "mytoken" not "mytoken # comment").
# NTFY_BASE_URL=https://ntfy.sh
# NTFY_TOPIC=your-topic-name
# NTFY_ACCESS_TOKEN=
# PUSH_ENABLED=true

# Kanban #1604 — Gmail tools (api/src/tools/email/)
# 1. https://console.cloud.google.com -> new project (or existing)
# 2. APIs & Services -> enable "Gmail API"
# 3. OAuth consent screen -> External (testing) -> add your Gmail as test user
# 4. Credentials -> Create OAuth client ID -> Desktop application -> download client_secret JSON
# 5. Set the values below, then restart api container
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8456/api/tools/email/auth/gmail/callback
# EMAIL_TOOLS_DAILY_UNITS_CAP=5000
# EMAIL_TOOLS_BULK_THRESHOLD=100

# Kanban #1608 — Outlook tools (api/src/tools/email/)
# 1. https://portal.azure.com → Azure Active Directory → App registrations → New registration
# 2. Name 'agent-teams email-tools'; Account type 'Personal Microsoft accounts only' (or 'Both')
# 3. Redirect URI = Web + http://localhost:8456/api/tools/email/auth/outlook/callback
# 4. API permissions → Microsoft Graph → Delegated → Mail.ReadWrite
# 5. Note Application (client) ID + Directory (tenant) ID
# 6. Set the values below, then restart api container
# AZURE_OAUTH_CLIENT_ID=
# AZURE_OAUTH_CLIENT_SECRET=
# AZURE_OAUTH_TENANT=consumers
# AZURE_OAUTH_REDIRECT_URI=http://localhost:8456/api/tools/email/auth/outlook/callback
